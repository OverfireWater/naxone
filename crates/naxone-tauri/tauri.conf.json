{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "NaxOne",
  "version": "0.5.14",
  "identifier": "com.naxone.app",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NaxOne",
        "width": 1024,
        "height": 680,
        "resizable": true,
        "center": true,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app"],
    "resources": ["resources/pie.phar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./nsis/installer-hooks.nsh",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://gitee.com/kz_y/naxone/raw/main/latest.json",
        "https://github.com/OverfireWater/naxone/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGNEIwNjY2NUU4NkE1QzgKUldUSXBZWmVaZ1pMZjNqN3ZiSTFIdmE0SDNrYWVyeGxvaEVXbXVFZGZCOWEwYXZUcHNZVWRXREEK",
      "windows": {
        "installerArgs": ["/S"]
      }
    }
  }
}
