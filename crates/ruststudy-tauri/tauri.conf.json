{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "RustStudy",
  "version": "0.2.2",
  "identifier": "com.ruststudy.app",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ruststudy-tauri/frontend run dev",
    "beforeBuildCommand": "npm --prefix ruststudy-tauri/frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "RustStudy",
        "width": 1024,
        "height": 680,
        "resizable": true,
        "center": true,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./nsis/installer-hooks.nsh",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
